# E2E Tests Umgebungskonfiguration
# Kopiere diese Datei zu .env.test.local und passe die Werte an

# Datenbank für Tests (kann auch development sein)
DATABASE_URL="postgresql://user:password@localhost:5432/pushlog_dev"

# NextAuth.js Konfiguration
NEXTAUTH_SECRET="your-secret-key-for-development"
NEXTAUTH_URL="http://localhost:3000"

